{
  "name": "nodepi",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "nodepi": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "build-bin": "npm run build && ./scripts/build-bin.sh",
    "install-bin": "./scripts/install-bin.sh",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chokidar": "^3.6.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "fuse.js": "^7.0.0",
    "picocolors": "^1.1.0",
    "vite-plugin-commonjs": "^0.10.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postject": "1.0.0-alpha.6",
    "prettier": "^3.8.4",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^1.3.1"
  }
}
